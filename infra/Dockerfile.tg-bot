# ============================================
# Multi-stage Dockerfile for Nigar TG Bot
# ============================================

# Stage 1: Install dependencies
FROM node:20-slim AS deps
WORKDIR /app
RUN corepack enable && corepack prepare pnpm@latest --activate

COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY apps/tg-bot/package.json apps/tg-bot/
COPY apps/api/package.json apps/api/
COPY apps/admin/package.json apps/admin/
COPY apps/mini-app/package.json apps/mini-app/
COPY packages/prisma-client/package.json packages/prisma-client/
COPY packages/shared-types/package.json packages/shared-types/
COPY packages/tsconfig/package.json packages/tsconfig/
COPY packages/eslint-config/package.json packages/eslint-config/

RUN pnpm install --frozen-lockfile --prod=false

# Stage 2: Build
FROM node:20-slim AS builder
WORKDIR /app
RUN corepack enable && corepack prepare pnpm@latest --activate

COPY --from=deps /app/node_modules ./node_modules
COPY . .

RUN pnpm db:generate
RUN pnpm --filter @nigar/shared-types build \
 && pnpm --filter @nigar/prisma-client build \
 && pnpm --filter @nigar/tg-bot build

# Stage 3: Production image
FROM node:20-slim AS runner
WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /app/apps/tg-bot/dist ./apps/tg-bot/dist
COPY --from=builder /app/apps/tg-bot/package.json ./apps/tg-bot/
# tg-bot's tsc compiles api source files into its own dist (same-process pattern),
# so we don't need to copy /app/apps/api/dist separately.
COPY --from=builder /app/packages/prisma-client/dist ./packages/prisma-client/dist
COPY --from=builder /app/packages/prisma-client/package.json ./packages/prisma-client/
COPY --from=builder /app/packages/prisma-client/prisma ./packages/prisma-client/prisma
COPY --from=builder /app/packages/shared-types/dist ./packages/shared-types/dist
COPY --from=builder /app/packages/shared-types/package.json ./packages/shared-types/
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/apps/tg-bot/node_modules ./apps/tg-bot/node_modules
COPY --from=builder /app/packages/prisma-client/node_modules ./packages/prisma-client/node_modules
COPY --from=builder /app/packages/shared-types/node_modules ./packages/shared-types/node_modules
COPY --from=builder /app/package.json ./

ENV NODE_ENV=production
ENV BOT_MODE=polling

CMD ["node", "apps/tg-bot/dist/apps/tg-bot/src/main.js"]
