# ============================================
# Nigar AI Psychologist — Production Env Template
# ============================================
# Copy to .env on VPS and fill in REAL values.
# NEVER commit the real .env to git.

# ---- App ----
NODE_ENV=production
API_PORT=3000
DOMAIN=your-domain.com
CORS_ORIGINS=https://your-domain.com

# ---- Admin Panel ----
# Use a SUBDOMAIN for admin, e.g. admin.your-domain.com
# Create an A-record pointing to the same VPS IP as the main domain.
ADMIN_DOMAIN=admin.your-domain.com
ADMIN_PORT=3001
# Caddy basic-auth layer (extra protection on top of AdminJS session auth).
# Generate hash with:
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext 'YOUR_PASSWORD'
# Copy the $2a$... output here.
ADMIN_BASIC_AUTH_HASH=$2a$14$placeholder_replace_with_real_bcrypt_hash

# ---- Database (Supabase) ----
# Pooled connection string (for app queries)
DATABASE_URL=postgresql://postgres.xxxxx:PASSWORD@aws-1-xxx.pooler.supabase.com:5432/postgres?pgbouncer=true
# Direct connection (for Prisma migrations only)
DIRECT_URL=postgresql://postgres.xxxxx:PASSWORD@aws-1-xxx.pooler.supabase.com:5432/postgres

# ---- Redis (local Docker container) ----
REDIS_URL=redis://redis:6379

# ---- Encryption (AES-256-GCM key, 64 hex chars) ----
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=GENERATE_64_HEX_CHARS_HERE

# ---- Telegram ----
TELEGRAM_BOT_TOKEN=your_new_bot_token_from_botfather
TELEGRAM_WEBHOOK_SECRET=random_secret_here
BOT_MODE=polling
# If using webhook mode:
# BOT_MODE=webhook
# WEBHOOK_DOMAIN=https://your-domain.com
# WEBHOOK_PATH=/telegram/webhook
# WEBHOOK_PORT=3001

# ---- LLM Providers ----
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=...
GROQ_API_KEY=gsk_...

# ---- Audio ----
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=your_voice_id

# ---- Stripe (for subscriptions) ----
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# ---- Admin ----
ADMIN_EMAIL=your-email@example.com
ADMIN_PASSWORD=strong_password_min_16_chars
ADMIN_TG_ID=123456789
ALERT_DEBUG_TOKEN=random_token_for_manual_alerts

# ---- Monitoring ----
SENTRY_DSN=https://...@sentry.io/...

# ---- Mailer (optional, for weekly KPI reports) ----
MAILER_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
REPORT_EMAIL_TO=
