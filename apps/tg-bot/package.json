    "@nestjs/bullmq": "^11.0.0",
    "@nestjs/schedule": "^5.0.1",
    "@nestjs/throttler": "^6.0.0",
    "@nigar/prisma-client": "workspace:*",
    "@nigar/shared-types": "workspace:*",
    "@sentry/nestjs": "^9.0.0",
    "@sentry/node": "^9.0.0",
    "bullmq": "^5.0.0",
    "fluent-ffmpeg": "^2.1.0",
