{
  "name": "@nigar/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "start:prod": "node dist/main",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:unit": "jest --testPathPattern='src/' --no-cache",
    "test:integration": "jest --testPathPattern='test/integration' --no-cache --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage --testPathPattern='src/'",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nigar/prisma-client": "workspace:*",
    "@nigar/shared-types": "workspace:*",
    "@nestjs/bullmq": "^11.0.0",
    "bullmq": "^5.0.0",
    "fluent-ffmpeg": "^2.1.0",
    "ioredis": "^5.4.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nigar/eslint-config": "workspace:*",
    "@nigar/tsconfig": "workspace:*",
    "@types/express": "^5.0.0",
    "@types/fluent-ffmpeg": "^2.1.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.7.0"
  }
}
