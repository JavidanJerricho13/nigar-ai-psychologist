# ============================================
# AI Psychologist Nigar — Environment Variables
# ============================================

# App
NODE_ENV=development
API_PORT=3000

# Database (Supabase PostgreSQL)
# Pooled connection (for app runtime via PgBouncer)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (for migrations — bypasses PgBouncer)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Redis
REDIS_URL=redis://localhost:6379

# Encryption
ENCRYPTION_KEY=your-32-byte-hex-key-here-change-in-prod

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret

# LLM Providers
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx
GOOGLE_AI_API_KEY=xxx

# STT / TTS
ELEVENLABS_API_KEY=xxx
ELEVENLABS_VOICE_ID=xxx

# Optional: Groq (fallback STT)
GROQ_API_KEY=xxx

# Stripe (payments)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Sentry (error tracking)
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Bot Mode (polling or webhook)
BOT_MODE=polling
WEBHOOK_DOMAIN=https://your-domain.com
WEBHOOK_PATH=/webhook/telegram
WEBHOOK_PORT=3001

# S3/R2 Backup (for pg-backup.sh)
S3_BUCKET=nigar-backups
S3_ENDPOINT=https://xxx.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=xxx

# ============================================
# Phase 6 — Alerting & Automation
# ============================================

# Admin panel credentials
ADMIN_EMAIL=admin@nigar.ai
ADMIN_PASSWORD=change-me

# Telegram chat id for admin alerts (private DM with the bot OR a channel id like -100…)
# To get your private DM id: send any message to @userinfobot
ADMIN_TG_ID=

# Token to authorize manual alert triggers via /internal/alerts/* (POST x-debug-token: …)
ALERT_DEBUG_TOKEN=change-me-to-a-long-random-string

# SMTP settings for the weekly KPI report (set MAILER_ENABLED=true to actually send)
MAILER_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Nigar AI <reports@nigar.ai>"
REPORT_EMAIL_TO=admin@nigar.ai
